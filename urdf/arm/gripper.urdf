<?xml version="1.0"?>
<!--
  urdf/arm/gripper.urdf
  Standalone parallel-jaw gripper sub-assembly.
  Attaches to the wrist (end_effector_link) of kuka_arm.urdf.
  Used as a reference; the gripper links are also inlined in kuka_arm.urdf
  so PyBullet loads a single combined URDF.

  Structure:
    gripper_base
      ├── finger_left  (prismatic +Y, 0→0.04 m open)
      └── finger_right (prismatic -Y, 0→0.04 m open)

  Force sensor modelled at gripper_base (read via p.getContactPoints).
-->
<robot name="gripper">

  <!-- Palm / base block -->
  <link name="gripper_base">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0"
               izz="0.0003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.08 0.04"/>
      </geometry>
      <material name="gripper_dark">
        <color rgba="0.15 0.15 0.15 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.08 0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- Left finger -->
  <link name="finger_left">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.00005" iyz="0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../../assets/meshes/gripper_finger.obj" scale="1 1 1"/>
      </geometry>
      <material name="finger_gray">
        <color rgba="0.55 0.55 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="finger_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="finger_left"/>
    <origin xyz="0  0.025 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.1"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- Right finger (mirror of left) -->
  <link name="finger_right">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0"
               iyy="0.00005" iyz="0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159"/>
      <geometry>
        <mesh filename="../../assets/meshes/gripper_finger.obj" scale="1 1 1"/>
      </geometry>
      <material name="finger_gray">
        <color rgba="0.55 0.55 0.55 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.015 0.015 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="finger_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="finger_right"/>
    <origin xyz="0 -0.025 0.04" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.1"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

</robot>
