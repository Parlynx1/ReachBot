<?xml version="1.0"?>
<!--
  urdf/base/base.urdf
  4-omniwheel mobile base with LiDAR, camera, and arm-mount.

  Visual geometry uses mesh files from assets/meshes/:
    base_chassis.obj  — chassis body
    omni_wheel.obj    — each of the 4 wheels

  Collision geometry always uses primitives (faster).
  If mesh files are missing PyBullet silently falls back to nothing visible;
  collision and physics still work correctly.

  Standalone wheel definition: see urdf/base/wheel.urdf
-->
<robot name="omni_base">

  <!-- ── Base chassis ─────────────────────────────────────────── -->
  <link name="base_link">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.15" ixy="0" ixz="0"
               iyy="0.15" iyz="0"
               izz="0.25"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../../assets/meshes/base_chassis.obj" scale="1 1 1"/>
      </geometry>
      <material name="chassis_dark">
        <color rgba="0.18 0.18 0.18 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.50 0.40 0.10"/></geometry>
    </collision>
  </link>

  <!-- ── LiDAR ────────────────────────────────────────────────── -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="sensor_black"><color rgba="0.05 0.05 0.05 1.0"/></material>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- ── Camera ───────────────────────────────────────────────── -->
  <link name="camera_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0"
               izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.06 0.03"/></geometry>
      <material name="camera_blue"><color rgba="0.1 0.3 0.8 1.0"/></material>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.26 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ── Wheel FL ──────────────────────────────────────────────── -->
  <link name="wheel_fl">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0"
               iyy="0.000900" iyz="0"
               izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_fl" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_fl"/>
    <origin xyz=" 0.175  0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ── Wheel FR ──────────────────────────────────────────────── -->
  <link name="wheel_fr">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0"
               iyy="0.000900" iyz="0"
               izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_fr" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_fr"/>
    <origin xyz=" 0.175 -0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ── Wheel RL ──────────────────────────────────────────────── -->
  <link name="wheel_rl">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0"
               iyy="0.000900" iyz="0"
               izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_rl" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_rl"/>
    <origin xyz="-0.175  0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ── Wheel RR ──────────────────────────────────────────────── -->
  <link name="wheel_rr">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0"
               iyy="0.000900" iyz="0"
               izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_rr" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_rr"/>
    <origin xyz="-0.175 -0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ── Arm mount ─────────────────────────────────────────────── -->
  <link name="arm_mount">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.06"/></geometry>
      <material name="mount_orange"><color rgba="0.9 0.45 0.0 1.0"/></material>
    </visual>
  </link>
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="arm_mount"/>
    <origin xyz="0.05 0 0.08" rpy="0 0 0"/>
  </joint>

</robot>