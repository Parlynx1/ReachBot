<?xml version="1.0"?>
<!--
  urdf/robot_full.urdf
  Combined ReachBot: omni-base + 3-DOF KUKA arm + parallel gripper.

  This is the authoritative single-file URDF for Modules 3-6.
  robot_loader.py loads base.urdf + kuka_arm.urdf separately and pins them
  with a constraint — this file is the human-readable merged version and can
  also be loaded directly via:
      p.loadURDF("urdf/robot_full.urdf", useFixedBase=False)

  Coordinate convention:
    base_link origin at chassis centre, z=0 at wheel contact plane.
    arm_base_link attached at [0.05, 0, 0.13] on base_link.

  Sensors (fixed links, no inertia):
    lidar_link    — top of chassis, 360° planar LiDAR
    camera_link   — front of chassis, RGB-D camera
    force_sensor  — end-effector, 6-axis F/T (simulated via contact query)

  Visual geometry: mesh where available, primitive fallback.
  Collision geometry: always primitives (faster simulation).
-->
<robot name="reachbot">

  <!-- ════════════════════════════════════════════════════════════════
       BASE CHASSIS
       ════════════════════════════════════════════════════════════════ -->

  <link name="base_link">
    <inertial>
      <mass value="8.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.15" ixy="0" ixz="0"
               iyy="0.15" iyz="0"
               izz="0.25"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../assets/meshes/base_chassis.obj" scale="1 1 1"/>
      </geometry>
      <material name="chassis_dark">
        <color rgba="0.18 0.18 0.18 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.50 0.40 0.10"/></geometry>
    </collision>
  </link>

  <!-- ── Sensors (fixed to base) ───────────────────────────────── -->

  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="sensor_black"><color rgba="0.05 0.05 0.05 1.0"/></material>
    </visual>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.04 0.06 0.03"/></geometry>
      <material name="camera_blue"><color rgba="0.1 0.3 0.8 1.0"/></material>
    </visual>
  </link>
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.26 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ── Omni wheels (×4) ──────────────────────────────────────── -->

  <!-- Front-Left -->
  <link name="wheel_fl">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0" iyy="0.000900" iyz="0" izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_fl" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_fl"/>
    <origin xyz=" 0.175  0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- Front-Right -->
  <link name="wheel_fr">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0" iyy="0.000900" iyz="0" izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_fr" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_fr"/>
    <origin xyz=" 0.175 -0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- Rear-Left -->
  <link name="wheel_rl">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0" iyy="0.000900" iyz="0" izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_rl" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_rl"/>
    <origin xyz="-0.175  0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- Rear-Right -->
  <link name="wheel_rr">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000477" ixy="0" ixz="0" iyy="0.000900" iyz="0" izz="0.000477"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <mesh filename="../assets/meshes/omni_wheel.obj" scale="1 1 1"/>
      </geometry>
      <material name="wheel_rubber"><color rgba="0.12 0.12 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.06" length="0.03"/></geometry>
    </collision>
  </link>
  <joint name="joint_wheel_rr" type="continuous">
    <parent link="base_link"/>
    <child  link="wheel_rr"/>
    <origin xyz="-0.175 -0.215 -0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════
       ARM MOUNT  (transition between base and arm)
       ════════════════════════════════════════════════════════════════ -->

  <link name="arm_mount">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.06"/></geometry>
      <material name="mount_orange"><color rgba="0.9 0.45 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.045" length="0.06"/></geometry>
    </collision>
  </link>
  <joint name="arm_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="arm_mount"/>
    <origin xyz="0.05 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════
       3-DOF KUKA ARM
       ════════════════════════════════════════════════════════════════ -->

  <!-- Arm base (attached to arm_mount) -->
  <link name="arm_base_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
      <material name="kuka_orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.06"/></geometry>
    </collision>
  </link>
  <joint name="arm_base_joint" type="fixed">
    <parent link="arm_mount"/>
    <child  link="arm_base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- Link 1 — shoulder yaw -->
  <link name="link1">
    <inertial>
      <mass value="1.2"/>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.20"/></geometry>
      <material name="kuka_orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><cylinder radius="0.035" length="0.20"/></geometry>
    </collision>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="arm_base_link"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="80" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Link 2 — elbow pitch -->
  <link name="link2">
    <inertial>
      <mass value="0.9"/>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry><cylinder radius="0.030" length="0.24"/></geometry>
      <material name="kuka_orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <geometry><cylinder radius="0.030" length="0.24"/></geometry>
    </collision>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="60" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Link 3 — wrist pitch -->
  <link name="link3">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.16"/></geometry>
      <material name="kuka_dark"><color rgba="0.20 0.20 0.20 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.025" length="0.16"/></geometry>
    </collision>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 0 0.24" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="40" velocity="2.5"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- End-effector -->
  <link name="end_effector_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.018"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1.0"/></material>
    </visual>
  </link>
  <joint name="ee_joint" type="fixed">
    <parent link="link3"/>
    <child  link="end_effector_link"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════
       GRIPPER
       ════════════════════════════════════════════════════════════════ -->

  <!-- Gripper palm -->
  <link name="gripper_base">
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0003"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.06 0.08 0.04"/></geometry>
      <material name="gripper_dark"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><box size="0.06 0.08 0.04"/></geometry>
    </collision>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="end_effector_link"/>
    <child  link="gripper_base"/>
    <origin xyz="0 0 0.01" rpy="0 0 0"/>
  </joint>

  <!-- Left finger -->
  <link name="finger_left">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="../assets/meshes/gripper_finger.obj" scale="1 1 1"/>
      </geometry>
      <material name="finger_gray"><color rgba="0.55 0.55 0.55 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.015 0.015 0.05"/></geometry>
    </collision>
  </link>
  <joint name="finger_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="finger_left"/>
    <origin xyz="0  0.025 0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.1"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- Right finger -->
  <link name="finger_right">
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0.14159"/>
      <geometry>
        <mesh filename="../assets/meshes/gripper_finger.obj" scale="1 1 1"/>
      </geometry>
      <material name="finger_gray"><color rgba="0.55 0.55 0.55 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry><box size="0.015 0.015 0.05"/></geometry>
    </collision>
  </link>
  <joint name="finger_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child  link="finger_right"/>
    <origin xyz="0 -0.025 0.04" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.04" effort="20" velocity="0.1"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- Force sensor frame (virtual, fixed to gripper_base) -->
  <link name="force_sensor_link">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="force_sensor_joint" type="fixed">
    <parent link="gripper_base"/>
    <child  link="force_sensor_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

</robot>
